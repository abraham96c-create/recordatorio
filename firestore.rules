rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Routes ---
    
    match /notes/{noteId} {
      // Allow read (get and list) if the user is authenticated and owns the data
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      
      // Allow create if authenticated and the note's userId matches the authenticated user
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Allow update if ownership is preserved
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid 
        && request.resource.data.userId == request.auth.uid;
        
      // Allow delete if authenticated and the note owner matches the authenticated user, or if document already deleted to avoid NPE
      allow delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    match /whatsappConfigs/{configId} {
      // Configns are strictly locked to the owner's Firebase Auth UID
      allow read, write: if isSignedIn() && configId == request.auth.uid;
    }
  }
}
